<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <color name="dolbyError">#BB0000</color>

    <dimen name="strokeSize">3dp</dimen>
    <dimen name="loadingSpinnerSize">48dp</dimen>

    <attr name="materialProgressBarStyle" format="reference" />
    <attr name="materialProgressSpinnerStyle" format="reference" />

    <!-- Extends the common DolbyTheme.Base with offline-specific widget styles -->
    <style name="DolbyTheme.Offline" parent="DolbyTheme.Base">
        <item name="materialCardViewStyle">@style/DolbyWidget.CardView.Offline</item>
        <item name="materialImageButtonStyle">@style/DolbyWidget.Button.Image.Offline</item>
        <item name="materialProgressBarStyle">@style/DolbyWidget.ProgressBar.Offline</item>
        <item name="materialProgressSpinnerStyle">@style/DolbyWidget.ProgressSpinner.Offline</item>
    </style>

    <style name="DolbyTheme.Offline.SplashScreen">
        <item name="android:windowBackground">@drawable/splash_screen</item>
    </style>

    <style name="DolbyWidget.CardView.Offline" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardMaxElevation">0dp</item>
        <item name="cardForegroundColor">@null</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="contentPadding">@dimen/spaceMargin</item>
        <item name="cardCornerRadius">@dimen/cornerSize</item>
        <item name="strokeWidth">@dimen/strokeSize</item>
    </style>

    <style name="DolbyWidget.Button.Image.Offline" parent="Widget.MaterialComponents.Button">
        <item name="android:minWidth">@dimen/minTouchTargetWidth</item>
        <item name="android:minHeight">@dimen/minTouchTargetHeight</item>
        <item name="android:insetTop">@null</item>
        <item name="android:insetBottom">@null</item>
        <item name="android:paddingLeft">@dimen/spaceMargin</item>
        <item name="android:paddingRight">@dimen/spaceMargin</item>
        <item name="iconPadding">@null</item>
        <item name="backgroundTint">@color/dolbyPurpleOpaque</item>
    </style>

    <!-- Theme overlay to set progress color to opaque purple -->
    <style name="DolbyThemeOverlay.ProgressBar" parent="">
        <item name="colorAccent">@color/dolbyPurpleOpaque</item>
    </style>

    <style name="DolbyWidget.ProgressBar.Offline" parent="Widget.AppCompat.ProgressBar.Horizontal">
        <item name="android:theme">@style/DolbyThemeOverlay.ProgressBar</item>
    </style>

    <style name="DolbyWidget.ProgressSpinner.Offline" parent="Widget.AppCompat.ProgressBar">
        <item name="android:theme">@style/DolbyThemeOverlay.ProgressBar</item>
    </style>

</resources>
