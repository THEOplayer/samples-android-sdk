<resources xmlns:android="http://schemas.android.com/apk/res/android">

    <color name="dolbyWhite">#FFFFFF</color>
    <color name="dolbyBlack">#000000</color>
    <color name="dolbyBlue">#3E44FE</color>
    <color name="dolbyPurple">#B38339FC</color>
    <color name="dolbyPurpleOpaque">#8339FC</color>

    <dimen name="spaceMarginSmall">6dp</dimen>
    <dimen name="spaceMargin">12dp</dimen>
    <dimen name="cornerSize">10dp</dimen>
    <dimen name="minTouchTargetWidth">48dp</dimen>
    <dimen name="minTouchTargetHeight">36dp</dimen>

    <attr name="materialTextViewLabelStyle" format="reference" />
    <attr name="materialTextViewHeaderStyle" format="reference" />
    <attr name="materialImageButtonStyle" format="reference" />

    <style name="DolbyTheme.Base" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:navigationBarColor">@color/dolbyPurple</item>
        <item name="android:statusBarColor">@color/dolbyPurple</item>
        <item name="android:windowBackground">@color/dolbyBlack</item>

        <item name="colorPrimary">@color/dolbyPurple</item>
        <item name="colorPrimaryDark">@color/dolbyPurple</item>
        <item name="colorPrimaryVariant">@color/dolbyBlack</item>
        <item name="colorOnPrimary">@color/dolbyWhite</item>
        <item name="colorSecondary">@color/dolbyWhite</item>
        <item name="colorSecondaryVariant">@color/dolbyWhite</item>
        <item name="colorOnSecondary">@color/dolbyWhite</item>
        <item name="colorSurface">@color/dolbyWhite</item>
        <item name="colorOnSurface">@color/dolbyPurple</item>

        <item name="minTouchTargetSize">@null</item>

        <item name="toolbarStyle">@style/Widget.MaterialComponents.Toolbar.Primary</item>
        <item name="materialTextViewLabelStyle">@style/DolbyWidget.TextView.Label</item>
        <item name="materialTextViewHeaderStyle">@style/DolbyWidget.TextView.Header</item>
        <item name="materialCardViewStyle">@style/DolbyWidget.CardView</item>
        <item name="materialButtonStyle">@style/DolbyWidget.Button</item>
        <item name="materialImageButtonStyle">@style/DolbyWidget.Button.Image</item>

        <item name="shapeAppearanceSmallComponent">@style/DolbyShape.SmallComponent</item>
    </style>

    <style name="DolbyShape.SmallComponent" parent="ShapeAppearance.MaterialComponents.SmallComponent">
        <item name="cornerSize">@dimen/cornerSize</item>
    </style>

    <style name="DolbyWidget.TextView.Label" parent="Widget.MaterialComponents.TextView">
        <item name="android:textColor">?attr/colorOnPrimary</item>
        <item name="android:paddingStart">@dimen/spaceMargin</item>
        <item name="android:paddingLeft">@dimen/spaceMargin</item>
        <item name="android:paddingEnd">@dimen/spaceMargin</item>
        <item name="android:paddingRight">@dimen/spaceMargin</item>
    </style>

    <style name="DolbyWidget.TextView.Header" parent="DolbyWidget.TextView.Label">
        <item name="android:textAppearance">?attr/textAppearanceSubtitle1</item>
    </style>

    <style name="DolbyWidget.CardView" parent="Widget.MaterialComponents.CardView">
        <item name="cardElevation">0dp</item>
        <item name="cardMaxElevation">0dp</item>
        <item name="cardForegroundColor">@null</item>
        <item name="cardBackgroundColor">?attr/colorSurface</item>
        <item name="contentPadding">@dimen/spaceMargin</item>
        <item name="cardCornerRadius">@dimen/cornerSize</item>
    </style>

    <style name="DolbyWidget.Button" parent="Widget.MaterialComponents.Button">
    </style>

    <style name="DolbyWidget.Button.Image" parent="DolbyWidget.Button">
        <item name="android:minWidth">@dimen/minTouchTargetWidth</item>
        <item name="android:minHeight">@dimen/minTouchTargetHeight</item>
        <item name="android:insetTop">@null</item>
        <item name="android:insetBottom">@null</item>
        <item name="android:paddingLeft">@dimen/spaceMargin</item>
        <item name="android:paddingRight">@dimen/spaceMargin</item>
        <item name="iconPadding">@null</item>
    </style>

    <style name="DolbyTheme.SplashScreen" parent="DolbyTheme.Base">
        <item name="android:windowBackground">@drawable/splash_screen</item>
    </style>

</resources>
